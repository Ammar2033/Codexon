{
  "model": {
    "name": "sample-image-classifier",
    "version": "1.0",
    "description": "A sample image classification model"
  },
  "runtime": {
    "framework": "onnx",
    "python": "3.12"
  },
  "resources": {
    "cpu": 2,
    "memory": "4GB",
    "gpu": 0
  },
  "api": {
    "endpoint": "/predict"
  },
  "billing": {
    "price_per_request": 0.002
  }
}